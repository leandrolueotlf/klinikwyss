<% var _name = typeof name !== 'undefined' ? name : ''; %>
<% var _label = typeof label !== 'undefined' ? label : ''; %>
<% var _ph = typeof placeholder !== 'undefined' ? placeholder : ''; %>
<% var segs = typeof fieldSegments !== 'undefined' && fieldSegments && fieldSegments[_name] ? fieldSegments[_name] : []; %>
<div>
  <label class="mb-1 block text-xs font-medium text-slate-600" for="<%= _name %>"><%= _label %></label>
  <% if (segs && segs.length) { %>
  <div class="segment-preview mb-2 rounded border border-slate-100 bg-slate-50 p-2 text-sm leading-relaxed" aria-label="Farbcodierung nach Berufsgruppe">
    <%- renderSegmentsHtml(segs) %>
  </div>
  <% } %>
  <input id="<%= _name %>" name="<%= _name %>" type="text" value="<%= akten[_name] || '' %>" class="field-input" placeholder="<%= _ph %>" />
</div>
