<% var redirectPage = typeof redirectPage !== 'undefined' ? redirectPage : 'beurteilung'; %>
<section id="sec-assessment" class="form-section scroll-mt-24 rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
    <h2 class="text-base font-semibold text-klinik-blue">Beurteilung &amp; Kontext</h2>
    <p class="mt-1 text-xs text-slate-600">Aktuelle Situation, Arbeit, Finanzen, Ziele, Wohnen, Soziales, Erfahrung</p>
    <% if (typeof sectionAudit !== 'undefined' && sectionAudit && sectionAudit.assessment) { %>
    <p class="mt-2 text-xs text-slate-500">
      Zuletzt gespeichert: <strong class="text-slate-700"><%= sectionAudit.assessment.by %></strong>
      <% if (sectionAudit.assessment.role) { %>
      <span class="seg seg-<%= sectionAudit.assessment.role %> ml-1 inline-block rounded px-1.5 py-0.5 text-[11px] font-semibold"><%= roleLabels[sectionAudit.assessment.role] || sectionAudit.assessment.role %></span>
      <% } %>
      · <%= formatDatum(sectionAudit.assessment.at) %>
    </p>
    <% } %>
  </div>
  <form method="post" action="<%= basePath %>/plan/fallakte" class="p-4 sm:p-5">
    <%- include('form-plan-context') %>
    <input type="hidden" name="section" value="assessment" />
    <div class="grid gap-8 md:grid-cols-2">
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-klinik-blue">Aktuelle psychische Situation</h3>
        <% const psy = [
          ['psy_eintritt', 'Was hat zum Klinikeintritt geführt?'],
          ['psy_symptome', 'Symptome'],
          ['psy_somatik', 'Somatik (pflegerelevant)'],
          ['psy_noxen', 'Noxen'],
          ['psy_bewaeltigung', 'Vorhandene Bewältigungsstrategien'],
          ['psy_bedeutung', 'Dinge, die für mich Bedeutung haben'],
          ['psy_risiko', 'Suizidalität, selbstschädigendes Verhalten, Fremdgefährdung, Entweichungsrisiko'],
          ['psy_besonderheiten', 'Besonderheiten (Haustierbetreuung, Kinderbetreuung während PKW usw.)'],
        ]; %>
        <% psy.forEach(function ([fname, flabel]) { %>
        <%- include('field-textarea-segmented', { name: fname, label: flabel, rows: 2 }) %>
        <% }); %>
        <h3 class="pt-4 text-sm font-semibold text-klinik-blue">Arbeitssituation</h3>
        <%- include('field-textarea-segmented', { name: 'arbeit_beruf', label: 'Angaben zum beruflichen Alltag', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'arbeit_grad', label: 'Beschäftigungsgrad und Arbeitgeber', rows: 2 }) %>
        <h3 class="pt-4 text-sm font-semibold text-klinik-blue">Finanzielle Situation</h3>
        <%- include('field-textarea-segmented', { name: 'finanz_situation', label: 'Aktuelle finanzielle Situation', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'finanz_schulden', label: 'Schulden und Schuldenberatung', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'finanz_sozialhilfe', label: 'Sozialhilfe, Ergänzungsleistungen usw.', rows: 2 }) %>
      </div>
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-klinik-blue">Ziele</h3>
        <%- include('field-textarea-segmented', { name: 'ziele_wuenschen', label: 'Was wünschen Sie sich?', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'ziele_aenderung', label: 'Was soll sich ändern?', rows: 2 }) %>
        <h3 class="pt-4 text-sm font-semibold text-klinik-blue">Wohnsituation</h3>
        <%- include('field-textarea-segmented', { name: 'wohn_situation', label: 'Aktuelle Wohnsituation', rows: 2 }) %>
        <h3 class="pt-4 text-sm font-semibold text-klinik-blue">Soziale Situation</h3>
        <%- include('field-textarea-segmented', { name: 'sozial_situation', label: 'Partnerschaft, Kinder inkl. Alter', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'sozial_bezug', label: 'Wichtige Bezugspersonen', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'sozial_stellen', label: 'Involvierte Stellen (KESB, IV, Sozialdienst, …)', rows: 2 }) %>
        <h3 class="pt-4 text-sm font-semibold text-klinik-blue">Erfahrung stationär und ambulant</h3>
        <%- include('field-textarea-segmented', { name: 'erf_stationaer', label: 'Stationäre / teilstationäre Aufenthalte', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'erf_ambulant', label: 'Ambulante Behandlungen', rows: 2 }) %>
        <%- include('field-textarea-segmented', { name: 'erf_netz', label: 'Ambulantes Netz (Kontaktdaten)', rows: 3 }) %>
      </div>
    </div>
    <div class="mt-6 flex justify-end border-t border-slate-100 pt-4">
      <button type="submit" class="rounded-lg bg-klinik-blue px-5 py-2 text-sm font-semibold text-white shadow hover:bg-blue-900">Beurteilung speichern</button>
    </div>
  </form>
</section>
