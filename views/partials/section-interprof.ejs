<section class="form-section mb-8 rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
    <h2 class="text-base font-semibold text-klinik-blue">Interprofessionelle Behandlungsplanung</h2>
  </div>
  <form method="post" action="/plan/fallakte" class="p-4 sm:p-5">
    <input type="hidden" name="fallnr" value="<%= fallnr %>" />
    <input type="hidden" name="user" value="<%= userRaw %>" />
    <input type="hidden" name="section" value="interprof" />
    <div class="mb-6">
      <label class="mb-1 block text-xs font-medium text-slate-600" for="ip_situation_zusammenfassung">Zusammenfassung und Paraphrase der aktuellen Situation</label>
      <textarea id="ip_situation_zusammenfassung" name="ip_situation_zusammenfassung" rows="4" class="field-textarea"><%= akten.ip_situation_zusammenfassung || '' %></textarea>
    </div>
    <div class="mb-6 overflow-x-auto rounded-lg border border-slate-200">
      <table class="w-full min-w-[720px] text-left text-xs sm:text-sm">
        <thead>
          <tr class="border-b border-slate-200 bg-slate-50 text-slate-700">
            <th class="px-2 py-2 font-medium">Nr.</th>
            <th class="px-2 py-2 font-medium">Problembereich / Bedarf</th>
            <th class="px-2 py-2 font-medium">Wie sehr leide ich darunter? (1–10)</th>
            <th class="px-2 py-2 font-medium">Beeinträchtigung Alltag (1–10)</th>
            <th class="px-2 py-2 font-medium">Kontrolle (1–10)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% prioRows.forEach(function (row, i) { %>
          <tr>
            <td class="whitespace-nowrap px-2 py-2 text-slate-500"><%= i + 1 %>.</td>
            <td class="px-2 py-2">
              <input type="text" name="prio_<%= i %>_problem" value="<%= row.problem || '' %>" class="w-full min-w-[8rem] rounded border border-slate-300 px-2 py-1 text-sm" />
            </td>
            <% ['leiden', 'alltag', 'kontrolle'].forEach(function (key) { %>
            <td class="px-2 py-2">
              <select name="prio_<%= i %>_<%= key %>" class="w-full max-w-[5rem] rounded border border-slate-300 bg-white px-1 py-1 text-sm">
                <option value="">—</option>
                <% range10.forEach(function (n) { %>
                <option value="<%= n %>" <%= String(row[key]) === String(n) ? 'selected' : '' %>><%= n %></option>
                <% }); %>
              </select>
            </td>
            <% }); %>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <p class="mb-4 text-xs text-slate-500">Priorisierung: Wo besteht aktuell die grösste Not / der grösste Leidensdruck?</p>
    <div class="space-y-4">
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-600" for="ip_gemeinsam_verstaendnis">Gemeinsames Verständnis und Beurteilung der Probleme und Bedürfnisse</label>
        <textarea id="ip_gemeinsam_verstaendnis" name="ip_gemeinsam_verstaendnis" rows="3" class="field-textarea"><%= akten.ip_gemeinsam_verstaendnis || '' %></textarea>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-600" for="ip_ressourcen">Ressourcen — was hat früher und bisher geholfen?</label>
        <textarea id="ip_ressourcen" name="ip_ressourcen" rows="3" class="field-textarea"><%= akten.ip_ressourcen || '' %></textarea>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-600" for="ip_bedarf">Was brauchen Sie jetzt, um besser mit den Problemen umzugehen?</label>
        <textarea id="ip_bedarf" name="ip_bedarf" rows="3" class="field-textarea"><%= akten.ip_bedarf || '' %></textarea>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-600" for="ip_pflege">Was kann ich als Pflegeperson dazu beitragen?</label>
        <textarea id="ip_pflege" name="ip_pflege" rows="3" class="field-textarea"><%= akten.ip_pflege || '' %></textarea>
      </div>
    </div>
    <div class="mt-6 flex justify-end border-t border-slate-100 pt-4">
      <button type="submit" class="rounded-lg bg-klinik-blue px-5 py-2 text-sm font-semibold text-white shadow hover:bg-blue-900">Interprofessionelle Planung speichern</button>
    </div>
  </form>
</section>
