<% var redirectPage = typeof redirectPage !== 'undefined' ? redirectPage : 'system'; %>
<section id="sec-system" class="form-section scroll-mt-24 rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="flex flex-col gap-2 border-b border-slate-100 bg-slate-50 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-base font-semibold text-klinik-blue">Systemgespräche</h2>
      <p class="mt-1 text-xs text-slate-600">Angehörige, Arbeitgeber, Behörden, ambulantes Netz …</p>
    </div>
    <a
      href="#system-new-form"
      class="inline-flex shrink-0 items-center gap-1 rounded-lg border border-klinik-blue bg-white px-3 py-1.5 text-xs font-semibold text-klinik-blue hover:bg-blue-50"
    >
      <span class="text-base leading-none">+</span> Zeile
    </a>
  </div>
  <div class="overflow-x-auto px-2 py-4">
    <% if (!systemgespraeche || systemgespraeche.length === 0) { %>
    <p class="px-2 py-4 text-center text-sm text-slate-500">Noch keine Systemgespräche. Unten <strong>+ Zeile</strong> zum Erfassen.</p>
    <% } else { %>
    <table class="w-full min-w-[720px] text-left text-sm">
      <thead>
        <tr class="border-b border-slate-200 text-xs uppercase text-slate-500">
          <th class="px-3 py-2 font-medium">Ziele / Thema</th>
          <th class="px-3 py-2 font-medium">Wann</th>
          <th class="px-3 py-2 font-medium">Beteiligte</th>
          <th class="px-3 py-2 font-medium">Zusammenfassung</th>
          <th class="px-3 py-2 font-medium">Erfasst von</th>
          <th class="px-3 py-2 font-medium"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% systemgespraeche.forEach(function (sg) { %>
        <% var sgRole = sg.ersteller_role || 'unknown'; %>
        <tr class="align-top">
          <td class="px-3 py-3"><%= sg.ziele_thema || '—' %></td>
          <td class="whitespace-nowrap px-3 py-3 text-slate-600"><%= sg.wann || '—' %></td>
          <td class="px-3 py-3 text-slate-700"><%= sg.beteiligte || '—' %></td>
          <td class="px-3 py-3 text-slate-600"><%= sg.zusammenfassung || '—' %></td>
          <td class="whitespace-nowrap px-3 py-3 text-xs font-medium">
            <span class="seg seg-<%= sgRole %> inline-block rounded px-1.5 py-0.5" title="<%= roleLabels[sgRole] || sgRole %>"><%= sg.ersteller || '—' %></span>
          </td>
          <td class="px-3 py-3">
            <form method="post" action="<%= basePath %>/plan/system/delete" onsubmit="return confirm('Dieses Systemgespräch löschen?');">
              <%- include('form-plan-context') %>
              <input type="hidden" name="id" value="<%= sg.id %>" />
              <button type="submit" class="text-xs font-medium text-red-700 hover:underline">Löschen</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
  <div id="system-new-form" class="scroll-mt-24 border-t border-slate-100 p-4 sm:p-6">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
      <h3 class="text-sm font-semibold text-slate-800">Systemgespräch hinzufügen</h3>
      <span class="text-xs text-slate-500">Gespeichert als: <strong class="seg seg-<%= role %>"><%= userLabel %></strong> · <strong><%= roleLabel %></strong></span>
    </div>
    <form method="post" action="<%= basePath %>/plan/system" class="space-y-3">
      <%- include('form-plan-context') %>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-600" for="ziele_thema">Ziele und Thema</label>
        <input id="ziele_thema" name="ziele_thema" type="text" class="field-input" />
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="wann">Wann</label>
          <input id="wann" name="wann" type="text" class="field-input" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="beteiligte">Beteiligte</label>
          <input id="beteiligte" name="beteiligte" type="text" class="field-input" />
        </div>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-slate-600" for="zusammenfassung">Zusammenfassung</label>
        <textarea id="zusammenfassung" name="zusammenfassung" rows="3" class="field-textarea"></textarea>
      </div>
      <button type="submit" class="rounded-lg bg-klinik-blue px-4 py-2 text-sm font-semibold text-white hover:bg-blue-900">Systemgespräch speichern</button>
    </form>
  </div>
</section>
