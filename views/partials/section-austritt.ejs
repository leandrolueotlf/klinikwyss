<section class="form-section mb-8 rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
    <h2 class="text-base font-semibold text-klinik-blue">Austrittsplanung</h2>
  </div>
  <form method="post" action="/plan/fallakte" class="p-4 sm:p-5">
    <input type="hidden" name="fallnr" value="<%= fallnr %>" />
    <input type="hidden" name="user" value="<%= userRaw %>" />
    <input type="hidden" name="section" value="austritt" />
    <div class="grid gap-6 md:grid-cols-2">
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-slate-800">Einbezug Angehörige</h3>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_angehoerige_welche">Welche</label>
          <input id="aust_angehoerige_welche" name="aust_angehoerige_welche" type="text" value="<%= akten.aust_angehoerige_welche || '' %>" class="field-input" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_angehoerige_kontakt">Kontaktaufnahme durch wen</label>
          <input id="aust_angehoerige_kontakt" name="aust_angehoerige_kontakt" type="text" value="<%= akten.aust_angehoerige_kontakt || '' %>" class="field-input" />
        </div>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Einbezug / Vernetzung ext. Stellen</h3>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_externe_stellen">IV, Sozialdienst, Case Management, …</label>
          <textarea id="aust_externe_stellen" name="aust_externe_stellen" rows="5" class="field-textarea"><%= akten.aust_externe_stellen || '' %></textarea>
        </div>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Nachsorgender Therapeut*in</h3>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_nachsorg_wer">Wer / Profession</label>
          <input id="aust_nachsorg_wer" name="aust_nachsorg_wer" type="text" value="<%= akten.aust_nachsorg_wer || '' %>" class="field-input" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_nachsorg_ersttermin">Ersttermin wann</label>
          <input id="aust_nachsorg_ersttermin" name="aust_nachsorg_ersttermin" type="text" value="<%= akten.aust_nachsorg_ersttermin || '' %>" class="field-input" />
        </div>
      </div>
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-slate-800">Weitere Unterstützung</h3>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_weitere_unterstuetzung">Was / Wer</label>
          <textarea id="aust_weitere_unterstuetzung" name="aust_weitere_unterstuetzung" rows="3" class="field-textarea"><%= akten.aust_weitere_unterstuetzung || '' %></textarea>
        </div>
        <div class="flex items-center gap-2 pt-1">
          <input id="aust_notfallplan" name="aust_notfallplan" type="checkbox" value="1" class="h-4 w-4 rounded border-slate-300 text-klinik-blue focus:ring-klinik-blue" <%= Number(akten.aust_notfallplan) === 1 ? 'checked' : '' %> />
          <label for="aust_notfallplan" class="text-sm text-slate-800">Notfallplan erarbeiten</label>
        </div>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Themen für amb. Therapie nach Austritt</h3>
        <div class="space-y-2">
          <input name="aust_amb_thema1" type="text" placeholder="1." value="<%= akten.aust_amb_thema1 || '' %>" class="field-input" />
          <input name="aust_amb_thema2" type="text" placeholder="2." value="<%= akten.aust_amb_thema2 || '' %>" class="field-input" />
          <input name="aust_amb_thema3" type="text" placeholder="3." value="<%= akten.aust_amb_thema3 || '' %>" class="field-input" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_spezielles">Spezielles / Besonderheiten / Bemerkungen</label>
          <input id="aust_spezielles" name="aust_spezielles" type="text" value="<%= akten.aust_spezielles || '' %>" class="field-input" />
        </div>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Psychiatrie-Spitex</h3>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_spitex_wer">Wer</label>
          <input id="aust_spitex_wer" name="aust_spitex_wer" type="text" value="<%= akten.aust_spitex_wer || '' %>" class="field-input" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-slate-600" for="aust_spitex_ersttermin">Ersttermin wann</label>
          <input id="aust_spitex_ersttermin" name="aust_spitex_ersttermin" type="text" value="<%= akten.aust_spitex_ersttermin || '' %>" class="field-input" />
        </div>
      </div>
    </div>
    <div class="mt-6 flex justify-end border-t border-slate-100 pt-4">
      <button type="submit" class="rounded-lg bg-klinik-blue px-5 py-2 text-sm font-semibold text-white shadow hover:bg-blue-900">Austrittsplanung speichern</button>
    </div>
  </form>
</section>
