<% var redirectPage = typeof redirectPage !== 'undefined' ? redirectPage : 'austritt'; %>
<section id="sec-austritt" class="form-section scroll-mt-24 rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="border-b border-slate-100 bg-slate-50 px-4 py-3">
    <h2 class="text-base font-semibold text-klinik-blue">Austrittsplanung</h2>
    <% if (typeof sectionAudit !== 'undefined' && sectionAudit && sectionAudit.austritt) { %>
    <p class="mt-2 text-xs text-slate-500">
      Zuletzt gespeichert: <strong class="text-slate-700"><%= sectionAudit.austritt.by %></strong>
      <% if (sectionAudit.austritt.role) { %>
      <span class="seg seg-<%= sectionAudit.austritt.role %> ml-1 inline-block rounded px-1.5 py-0.5 text-[11px] font-semibold"><%= roleLabels[sectionAudit.austritt.role] || sectionAudit.austritt.role %></span>
      <% } %>
      · <%= formatDatum(sectionAudit.austritt.at) %>
    </p>
    <% } %>
  </div>
  <form method="post" action="<%= basePath %>/plan/fallakte" class="p-4 sm:p-5">
    <%- include('form-plan-context') %>
    <input type="hidden" name="section" value="austritt" />
    <div class="grid gap-6 md:grid-cols-2">
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-slate-800">Einbezug Angehörige</h3>
        <%- include('field-input-segmented', { name: 'aust_angehoerige_welche', label: 'Welche', placeholder: '' }) %>
        <%- include('field-input-segmented', { name: 'aust_angehoerige_kontakt', label: 'Kontaktaufnahme durch wen', placeholder: '' }) %>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Einbezug / Vernetzung ext. Stellen</h3>
        <%- include('field-textarea-segmented', { name: 'aust_externe_stellen', label: 'IV, Sozialdienst, Case Management, …', rows: 5 }) %>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Nachsorgender Therapeut*in</h3>
        <%- include('field-input-segmented', { name: 'aust_nachsorg_wer', label: 'Wer / Profession', placeholder: '' }) %>
        <%- include('field-input-segmented', { name: 'aust_nachsorg_ersttermin', label: 'Ersttermin wann', placeholder: '' }) %>
      </div>
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-slate-800">Weitere Unterstützung</h3>
        <%- include('field-textarea-segmented', { name: 'aust_weitere_unterstuetzung', label: 'Was / Wer', rows: 3 }) %>
        <div class="flex items-center gap-2 pt-1">
          <input id="aust_notfallplan" name="aust_notfallplan" type="checkbox" value="1" class="h-4 w-4 rounded border-slate-300 text-klinik-blue focus:ring-klinik-blue" <%= Number(akten.aust_notfallplan) === 1 ? 'checked' : '' %> />
          <label for="aust_notfallplan" class="text-sm text-slate-800">Notfallplan erarbeiten</label>
        </div>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Themen für amb. Therapie nach Austritt</h3>
        <div class="space-y-2">
          <%- include('field-input-segmented', { name: 'aust_amb_thema1', label: '1.', placeholder: '1.' }) %>
          <%- include('field-input-segmented', { name: 'aust_amb_thema2', label: '2.', placeholder: '2.' }) %>
          <%- include('field-input-segmented', { name: 'aust_amb_thema3', label: '3.', placeholder: '3.' }) %>
        </div>
        <%- include('field-input-segmented', { name: 'aust_spezielles', label: 'Spezielles / Besonderheiten / Bemerkungen', placeholder: '' }) %>
        <h3 class="pt-2 text-sm font-semibold text-slate-800">Psychiatrie-Spitex</h3>
        <%- include('field-input-segmented', { name: 'aust_spitex_wer', label: 'Wer', placeholder: '' }) %>
        <%- include('field-input-segmented', { name: 'aust_spitex_ersttermin', label: 'Ersttermin wann', placeholder: '' }) %>
      </div>
    </div>
    <div class="mt-6 flex justify-end border-t border-slate-100 pt-4">
      <button type="submit" class="rounded-lg bg-klinik-blue px-5 py-2 text-sm font-semibold text-white shadow hover:bg-blue-900">Austrittsplanung speichern</button>
    </div>
  </form>
</section>
