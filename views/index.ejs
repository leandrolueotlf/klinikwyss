<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Behandlungsplanung — Fall <%= fallnr %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: { klinik: { blue: "#1e40af" } },
          },
        },
      };
    </script>
    <link rel="stylesheet" href="/style.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-slate-50 font-sans text-slate-900 antialiased" style="font-family: Inter, Arial, sans-serif">
    <header class="border-b border-slate-200 bg-klinik-blue text-white shadow-md">
      <div class="mx-auto max-w-5xl px-3 py-4 sm:px-4">
        <p class="text-xs font-medium uppercase tracking-wide text-blue-100">Digitale Behandlungsplanung</p>
        <div class="mt-1 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
          <h1 class="text-lg font-semibold sm:text-xl">Fallnummer: <span class="font-bold"><%= fallnr %></span></h1>
          <p class="text-sm text-blue-100">Benutzer: <span class="font-medium text-white"><%= userLabel %></span></p>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-3 py-6 sm:px-4">
      <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900" role="status"><%= flash %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900" role="alert"><%= error %></div>
      <% } %>

      <p class="mb-6 text-xs text-slate-600">
        Alle Bereiche werden pro Fallnummer gespeichert. Nutzen Sie die Speichern-Buttons je Abschnitt.
      </p>

      <%- include('partials/section-assessment') %>
      <%- include('partials/section-interprof') %>
      <%- include('partials/section-planzeilen') %>
      <%- include('partials/section-system') %>
      <%- include('partials/section-austritt') %>
    </main>
  </body>
</html>
