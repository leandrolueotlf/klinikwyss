# Hostinger setzt PORT automatisch. Lokal optional:
# PORT=3000

# Basis-URL-Pfad für alle Routen (Standard: /pkw-demo)
# App erreichbar unter z. B. https://domain.ch/pkw-demo/plan?fallnr=…
# Root ohne Präfix: BASE_PATH=/
# BASE_PATH=/pkw-demo

# Optional: eigener Pfad zur SQLite-Datei (Standard: ./data/planungen.db)
# DB_PATH=/var/data/planungen.db
